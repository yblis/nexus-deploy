# ============================================================
# Nexus RMM — Configuration
# ============================================================
# Copiez ce fichier en .env et adaptez les valeurs.
#
#   cp .env.example .env
#
# IMPORTANT : Changez impérativement les mots de passe et le
# JWT_SECRET avant le premier démarrage.
# ============================================================

# ── Version ──
# Tag de l'image Docker à utiliser (ex: latest, 1.0.0, 1.2.3)
NEXUS_VERSION=latest

# ── Base de données PostgreSQL ──
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHENGE_ME
POSTGRES_DB=nexus

# ── Backend API ──
# Clé secrète pour les tokens JWT (minimum 32 caractères aléatoires)
# Générez avec : openssl rand -hex 32
JWT_SECRET=CHENGE_ME

# Port interne de l'API (ne pas modifier sauf besoin spécifique)
API_PORT=8080

# ── Réseau ──
# Domaine public de votre instance Nexus (ex: nexus.example.com)
NEXUS_DOMAIN=nexus.example.com

# IP publique du serveur (pour la connexion des agents)
# Laisser vide pour détection automatique
NEXUS_SERVER_IP=

# ── Frontend ──
# Port d'écoute du dashboard web sur le serveur hôte
WEB_PORT=3333
